generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String               @id @default(uuid())
  email        String               @unique
  name         String
  passwordHash String
  createdAt    DateTime             @default(now())
  lastLogin    DateTime             @default(now())
  logs         LogEntry[]
  threats      ThreatIntelligence[]
  alerts       SecurityAlert[]
  apiKeys      ApiKey[]
}

model ApiKey {
  id         String    @id @default(uuid())
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  name       String
  keyHash    String    @unique
  prefix     String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revoked    Boolean   @default(false)

  @@index([userId])
}

model LogEntry {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  timestamp  DateTime
  sourceIp   String
  logType    String
  message    String
  severity   String
  rawLog     String?
  parsedAt   DateTime
}

model ThreatIntelligence {
  id                   String   @id @default(uuid())
  user                 User     @relation(fields: [userId], references: [id])
  userId               String
  ipAddress            String
  threatScore          Int
  threatLevel          String
  lastSeen             DateTime
  status               String
  failedLogins         Int
  repeatedAccess       Int
  description          String
  detectedAttackTypes  String   @default("[]")
  totalSuspiciousEvents Int?
  suspicious           Boolean?
  enrichment           String?
  algorithmReasoning   String?
  detectionMethods     String   @default("[]")
  confidenceScore      Int?
  riskFactors          String?
  recommendations      String   @default("[]")
}

model SecurityAlert {
  id            String   @id @default(uuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  alertType     String
  severity      String
  title         String
  description   String
  sourceIp      String
  timestamp     DateTime
  detectedAt    DateTime
  status        String
  threatId      String?
  indicators    String?
  recommendation String?
}
