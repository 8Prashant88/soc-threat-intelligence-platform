# SecureLogTI — environment configuration
# Copy this file to `.env.local` and fill in values as needed.
#
#   cp .env.example .env.local
#
# All variables below are OPTIONAL. The app runs fully without them —
# IP reputation falls back to a built-in local heuristics database.

# AbuseIPDB API key — enables richer live IP reputation enrichment.
# Get a free key at https://www.abuseipdb.com/account/api
# Leave blank to use the offline reputation heuristics.
ABUSEIPDB_API_KEY=

# The SQLite database location is configured in prisma/schema.prisma
# (file:./dev.db) and does not need to be set here.
